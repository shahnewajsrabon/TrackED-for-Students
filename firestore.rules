rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // Default deny
    }

    function isSignedIn() { return request.auth != null; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && userId == request.auth.uid;
    }
    
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update: if isSignedIn() && existing().user_id == request.auth.uid;
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().created_by == request.auth.uid;
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && existing().created_by == request.auth.uid;
    }

    match /messages/{messageId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
    }

    match /tasks/{taskId} {
       allow read: if isSignedIn() && existing().user_id == request.auth.uid;
       allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
       allow update: if isSignedIn() && existing().user_id == request.auth.uid;
       allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    match /notes/{noteId} {
       allow read: if isSignedIn() && existing().user_id == request.auth.uid;
       allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
       allow update: if isSignedIn() && existing().user_id == request.auth.uid;
       allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    match /decks/{deckId} {
       allow read: if isSignedIn() && existing().user_id == request.auth.uid;
       allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
       allow update: if isSignedIn() && existing().user_id == request.auth.uid;
       allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    match /exams/{examId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn() && incoming().creator_id == request.auth.uid;
       allow update: if isSignedIn();
       allow delete: if isSignedIn() && existing().creator_id == request.auth.uid;
    }

    match /exam_participants/{participantId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
       allow update: if isSignedIn() && existing().user_id == request.auth.uid;
       allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }
    
    match /exam_keys/{keyId} {
       allow read: if false; // Accessed securely via Admin SDK on the backend
       allow create: if isSignedIn() && incoming().creator_id == request.auth.uid;
       allow update, delete: if isSignedIn() && existing().creator_id == request.auth.uid;
    }
  }
}
